NODE_ENV=development

FRONTEND_PORT=5173
ADMIN_PORT=5174
BACKEND_PORT=8080
POSTGRES_PORT=5432

# Frontend/Admin should use same-origin via Nginx proxy in production.
VITE_API_URL=/api

DATABASE_URL=postgresql://postgres:change_me@postgres:5432/dinhdung_transport?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:change_me@postgres:5432/dinhdung_transport?schema=public

# Use a strong secret. Minimum 32 chars, recommended 64 random chars.
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_characters

# Local:
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# Public:
# CORS_ORIGINS=https://nhaxedinhdung.vn,https://www.nhaxedinhdung.vn,https://admin.nhaxedinhdung.vn
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Physical storage directory. Public image URLs still go through /image/...
UPLOAD_DIR=uploads
RUN_SEED_ON_BOOT=false

# Only use these when seeding a new environment.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
