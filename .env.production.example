NODE_ENV=production

FRONTEND_PORT=5173
ADMIN_PORT=5174
BACKEND_PORT=8080

# Frontend/Admin should use same-origin via Nginx proxy in production.
VITE_API_URL=/api

# Replace the password with your real PostgreSQL password on server.
POSTGRES_PASSWORD=change_me_on_server
DATABASE_URL=postgresql://postgres:change_me_on_server@postgres:5432/dinhdung_transport?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:change_me_on_server@postgres:5432/dinhdung_transport?schema=public

# Use a strong random secret, minimum 32 chars, recommended 64 chars.
JWT_SECRET=replace_with_a_strong_random_secret_for_production

# Optional Cloudflare Turnstile anti-bot layer for production.
# Set both values together to enable it. Leave both empty to keep internal captcha only.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Production origins for nhaxedinhdung.vn
CORS_ORIGINS=https://nhaxedinhdung.vn,https://www.nhaxedinhdung.vn

# Physical storage directory inside backend container.
UPLOAD_DIR=/app/uploads
RUN_SEED_ON_BOOT=false

# Only set these if you want to seed a brand-new server manually.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
