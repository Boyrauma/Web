generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model AdminUser {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  passwordHash         String
  fullName             String
  role                 String                 @default("super_admin")
  permissions          String[]               @default([])
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  handledBookings      BookingRequest[]       @relation("BookingHandledByAdmin")
  bookingStatusChanges BookingStatusHistory[] @relation("BookingStatusChangedByAdmin")
  activityLogs         AdminActivityLog[]     @relation("AdminActivityLogs")
}

model VehicleCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vehicles    Vehicle[]
}

model Vehicle {
  id               String          @id @default(cuid())
  categoryId       String
  name             String
  slug             String          @unique
  seatCount        Int
  shortDescription String?
  description      String?
  features         String[]
  isFeatured       Boolean         @default(false)
  isPublished      Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  category         VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images           VehicleImage[]
  scheduleNotes    ScheduleNote[]
  maintenanceLogs  VehicleMaintenance[]
  tripPayments     VehicleTripPayment[]
  tripExpenses      TripExpense[]
  reminders         Reminder[]
  assignedBookings BookingRequest[] @relation("BookingAssignedVehicle")
  trips            Trip[]
}

model VehicleImage {
  id        String   @id @default(cuid())
  vehicleId String
  imageUrl  String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookingRequest {
  id                String                 @id @default(cuid())
  customerName      String
  phoneNumber       String
  pickupLocation    String
  dropoffLocation   String
  tripDate          DateTime?
  passengerCount    Int?
  note              String?
  status            String                 @default("new")
  internalNote      String?
  cancelReason      String?
  confirmedAt       DateTime?
  completedAt       DateTime?
  handledByAdminId  String?
  assignedVehicleId String?
  assignedDriverId  String?
  tripId            String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  notifications     NotificationLog[]
  scheduleNotes     ScheduleNote[]
  tripPayments      VehicleTripPayment[]
  tripExpenses       TripExpense[]
  reminders          Reminder[]
  assignedVehicle   Vehicle?               @relation("BookingAssignedVehicle", fields: [assignedVehicleId], references: [id], onDelete: SetNull)
  assignedDriver    Driver?                @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
  handledByAdmin    AdminUser?             @relation("BookingHandledByAdmin", fields: [handledByAdminId], references: [id], onDelete: SetNull)
  statusHistory     BookingStatusHistory[]
  trip              Trip?                  @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([assignedVehicleId, tripDate])
  @@index([assignedDriverId, tripDate])
  @@index([handledByAdminId])
  @@index([tripId, tripDate])
}

model Customer {
  id          String   @id @default(cuid())
  fullName    String
  phoneNumber String
  phoneKey    String   @unique
  status      String   @default("regular")
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, updatedAt])
}

model Driver {
  id               String           @id @default(cuid())
  fullName         String
  phoneNumber      String           @unique
  status           String           @default("available")
  note             String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  assignedBookings BookingRequest[]
  trips            Trip[]
  reminders        Reminder[]

  @@index([status, isActive])
}

model Trip {
  id              String           @id @default(cuid())
  title           String
  tripDate        DateTime?
  pickupLocation  String?
  dropoffLocation String?
  vehicleId       String?
  driverId        String?
  status          String           @default("draft")
  note            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver          Driver?          @relation(fields: [driverId], references: [id], onDelete: SetNull)
  bookings        BookingRequest[]
  tripExpenses    TripExpense[]
  reminders       Reminder[]

  @@index([tripDate, status])
  @@index([vehicleId, tripDate])
  @@index([driverId, tripDate])
}

model BookingStatusHistory {
  id               String         @id @default(cuid())
  bookingId        String
  fromStatus       String?
  toStatus         String
  note             String?
  changedByAdminId String?
  createdAt        DateTime       @default(now())
  booking          BookingRequest @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedByAdmin   AdminUser?     @relation("BookingStatusChangedByAdmin", fields: [changedByAdminId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([changedByAdminId, createdAt])
}

model AdminActivityLog {
  id          String     @id @default(cuid())
  adminId     String?
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  description String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  admin       AdminUser? @relation("AdminActivityLogs", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([entityType, createdAt])
  @@index([action, createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id           String          @id @default(cuid())
  channel      String
  eventType    String
  status       String
  recipient    String?
  message      String?
  errorMessage String?
  bookingId    String?
  createdAt    DateTime        @default(now())
  booking      BookingRequest? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([channel, eventType, createdAt])
  @@index([bookingId])
}

model ScheduleNote {
  id              String         @id @default(cuid())
  vehicleId       String
  bookingRequestId String?
  title           String
  customerName    String?
  phoneNumber     String?
  tripDate        DateTime?
  pickupLocation  String?
  dropoffLocation String?
  status          String         @default("scheduled")
  note            String?
  archivedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  vehicle         Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  bookingRequest  BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: SetNull)
  tripPayment     VehicleTripPayment?
  reminders       Reminder[]

  @@index([vehicleId, tripDate])
  @@index([bookingRequestId])
  @@index([archivedAt, tripDate])
}

model VehicleTripPayment {
  id              String         @id @default(cuid())
  vehicleId       String
  scheduleNoteId  String?        @unique
  bookingRequestId String?       @unique
  title           String
  customerName    String?
  phoneNumber     String?
  tripDate        DateTime?
  pickupLocation  String?
  dropoffLocation String?
  amount          Float?
  paymentStatus   String         @default("unpaid")
  collectedAt     DateTime?
  note            String?
  archivedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  vehicle         Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  scheduleNote    ScheduleNote?  @relation(fields: [scheduleNoteId], references: [id], onDelete: SetNull)
  bookingRequest  BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: SetNull)

  @@index([vehicleId, tripDate])
  @@index([paymentStatus, tripDate])
  @@index([bookingRequestId])
  @@index([archivedAt, tripDate])
}

model TripExpense {
  id               String          @id @default(cuid())
  tripId           String?
  bookingRequestId String?
  vehicleId        String?
  title            String
  expenseType      String          @default("other")
  amount           Float
  expenseDate      DateTime?
  paidBy           String?
  note             String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  trip             Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull)
  bookingRequest   BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: SetNull)
  vehicle          Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([expenseDate, expenseType])
  @@index([tripId])
  @@index([bookingRequestId])
  @@index([vehicleId, expenseDate])
}

model Reminder {
  id               String          @id @default(cuid())
  title            String
  reminderType     String          @default("manual")
  remindAt         DateTime
  status           String          @default("pending")
  targetType       String?
  targetId         String?
  uniqueKey        String?         @unique
  bookingRequestId String?
  scheduleNoteId   String?
  tripId           String?
  vehicleId        String?
  driverId         String?
  note             String?
  sentAt           DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  bookingRequest   BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: SetNull)
  scheduleNote     ScheduleNote?   @relation(fields: [scheduleNoteId], references: [id], onDelete: SetNull)
  trip             Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull)
  vehicle          Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver           Driver?         @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([status, remindAt])
  @@index([targetType, targetId])
  @@index([bookingRequestId])
  @@index([scheduleNoteId])
  @@index([tripId])
  @@index([vehicleId])
  @@index([driverId])
}

model VehicleMaintenance {
  id              String   @id @default(cuid())
  vehicleId       String
  title           String
  maintenanceType String   @default("oil_change")
  licensePlate    String?
  serviceDate     DateTime
  nextServiceDate DateTime?
  odometerKm      Int?
  cost            Float?
  status          String   @default("completed")
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, serviceDate])
  @@index([maintenanceType, status])
}
